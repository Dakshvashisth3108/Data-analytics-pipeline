# ===========================================================================
# Example environment file for the Streamlit container.
#
# Copy to `.env` in this folder and `docker compose` picks it up
# automatically. Every var here uses the project's DOUBLE-UNDERSCORE
# convention, which the config loader maps onto configs/app.yaml:
#     NL2SQL__OLLAMA__BASE_URL  ->  nl2sql.ollama.base_url
# ===========================================================================

# Where the container finds Ollama. Inside a container "localhost" is the
# container itself — host.docker.internal points at the host machine.
NL2SQL__OLLAMA__BASE_URL=http://host.docker.internal:11434

# Which local model Ollama should use.
NL2SQL__OLLAMA__MODEL=gemma2:2b

# Log verbosity for the startup script (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO
